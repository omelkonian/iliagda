Vowel?     = DecidableВ№ Vowel     вҲӢ decВ№
Consonant? = DecidableВ№ Consonant вҲӢ decВ№

onlyVowels : List Letter вҶ’ List Letter
onlyVowels = L.filter Vowel?

вҷҜvowels : List Letter вҶ’ в„•
вҷҜvowels = length вҲҳ onlyVowels

module _ {l ls} where

  onlyVowelsвҲ· : onlyVowels (l вҲ· ls) вүЎ onlyVowels [ l ] ++ onlyVowels ls
  onlyVowelsвҲ· = L.filter-++ Vowel? [ l ] ls

  vowelsвҲ· : vowels (l вҲ· ls) вүЎ vowels [ l ] + вҷҜvowels ls
  vowelsвҲ· =
    let open вүЎ-Reasoning in
    begin
      vowels (l вҲ· ls)
    вүЎвҹЁвҹ©
      length (onlyVowels (l вҲ· ls))
    вүЎвҹЁ cong length onlyVowelsвҲ· вҹ©
      length (onlyVowels [ l ] ++ onlyVowels ls)
    вүЎвҹЁ L.length-++ (onlyVowels [ l ]) вҹ©
      length (onlyVowels [ l ]) + length (onlyVowels ls)
    вүЎвҹЁвҹ©
      vowels [ l ] + вҷҜvowels ls
    вҲҺ

vowelsDi : (l , lвҖІ) вҲҲ pairs (toList sy) вҶ’ vowels sy вүҘ vowels [ l вЁҫ lвҖІ ]
vowelsDi {sy = [ _ ]} ()
vowelsDi {sy = l вҲ· lвҖІ вҲ· ls} рқҹҳ =
  let open Nat.вүӨ-Reasoning in
  begin
    vowels [ l вЁҫ lвҖІ ]
  вүЎвҹЁ vowelsвҲ· {l} вҹ©
    vowels [ l ] + vowels [ lвҖІ ]
  вүӨвҹЁ Nat.mвүӨm+n _ _ вҹ©
    vowels [ l ] + vowels [ lвҖІ ] + вҷҜvowels ls
  вүЎвҹЁ Nat.+-assoc (vowels [ l ]) _ _ вҹ©
    vowels [ l ] + (vowels [ lвҖІ ] + вҷҜvowels ls)
  вүЎЛҳвҹЁ cong (_ +_) $ vowelsвҲ· {lвҖІ} вҹ©
    vowels [ l ] + vowels (lвҖІ вҲ· ls)
  вүЎЛҳвҹЁ vowelsвҲ· {l} вҹ©
    vowels (l вҲ· lвҖІ вҲ· ls)
  вҲҺ
vowelsDi {l}{lвҖІ}{sy = lвҶ“ вҲ· ls@(_ вҲ· _)} (вҶ  p) =
  let open Nat.вүӨ-Reasoning in
  begin
    vowels [ l вЁҫ lвҖІ ]
  вүӨвҹЁ vowelsDi p вҹ©
    вҷҜvowels ls
  вүӨвҹЁ Nat.mвүӨn+m _ _ вҹ©
    vowels [ lвҶ“ ] + вҷҜvowels ls
  вүЎЛҳвҹЁ vowelsвҲ· {lвҶ“} вҹ©
    vowels (lвҶ“ вҲ· ls)
  вҲҺ

Di-vowelsвүЎ2 : Diphthong (l , lвҖІ) вҶ’ vowels [ l вЁҫ lвҖІ ] вүЎ 2
Di-vowelsвүЎ2 {l}{lвҖІ} di =
  let
    vl , vlвҖІ = DiвҮ’Vowel di
    open вүЎ-Reasoning
  in
  begin
    vowels [ l вЁҫ lвҖІ ]
  вүЎвҹЁ cong length $ L.filter-accept Vowel? vl вҹ©
    1 + vowels [ lвҖІ ]
  вүЎвҹЁ cong (suc вҲҳ length) $ L.filter-accept Vowel? vlвҖІ вҹ©
    2
  вҲҺ

вҲЈDipthongвҲЈ>1 : AnyГ— Diphthong sy вҶ’ vowels sy > 1
вҲЈDipthongвҲЈ>1 {sy} diвҲҲ =
  let (l , lвҖІ) , diвҲҲ , di = satisfiedвҖІ diвҲҲ
  in subst (_ вүҘ_) (Di-vowelsвүЎ2 di) (vowelsDi diвҲҲ)

В¬bothByNature : В¬ ((sy ~ в”Җ) Г— (sy ~ В·))
В¬bothByNature {sy = sy} (longByNature long , shortByNature В·vвҲҲ v1)
  with long
... | injвӮҒ di =
  let 1<1 = subst (_> 1) v1 (вҲЈDipthongвҲЈ>1 di) in
  Nat.<-irrefl refl 1<1
... | injвӮӮ (injвӮҒ в”ҖvвҲҲ) =
  let _ , В·v , в”Җv = L.Any.satisfied
                  $ find-вҲ© decВ№ В·VowelвҮ’Vowel в”ҖVowelвҮ’Vowel (toList sy) v1 В·vвҲҲ в”ҖvвҲҲ
  in В¬В·в”ҖVowel (В·v , в”Җv)
... | injвӮӮ (injвӮӮ cvвҲҲ) =
  let _ , В·v , cv = L.Any.satisfied
                  $ find-вҲ© decВ№ В·VowelвҮ’Vowel CircвҮ’Vowel (toList sy) v1 В·vвҲҲ cvвҲҲ
  in В¬В·cVowel (В·v , cv)

рқҹҷ-theQuantity? :
  (sy : Syllable) вҶ’
    (вҲғ О» (q : Quantity) вҶ’
        (sy ~ q)
      Г— (вҲҖ {qвҖІ} вҶ’ sy ~ qвҖІ вҶ’ qвҖІ вүЎ q))
  вҠҺ NonDerivable {B = Quantity} sy
рқҹҷ-theQuantity? sy
  with Вҝ AnyГ— Diphthong sy
       вҠҺ Any в”ҖVowel sy
       вҠҺ Any HasCircumflex sy Вҝ
... | yes long =
  let ~в”Җ = longByNature long in
  injвӮҒ $ в”Җ
       , ~в”Җ
       , О» where (longByNature _) вҶ’ refl
                 ~В·@(shortByNature _ _) вҶ’ вҠҘ-elim $ В¬bothByNature (~в”Җ , ~В·)
... | no В¬long
  with Вҝ Any В·Vowel sy
       Г— vowels sy вүЎ 1 Вҝ
... | no В¬h
  = injвӮӮ О» where _ (longByNature long) вҶ’ В¬long long
                 _ (shortByNature В·vвҲҲ v1) вҶ’ В¬h (В·vвҲҲ , v1)
... | yes (В·vвҲҲ , v1) =
  let ~В· = shortByNature В·vвҲҲ v1 in
  injвӮҒ $ В·
       , ~В·
       , О» where ~в”Җ@(longByNature _) вҶ’ вҠҘ-elim $ В¬bothByNature (~в”Җ , ~В·)
                 (shortByNature _ _) вҶ’ refl

_~вӮҒ?_ : вҲҖ (sy : Syllable) (q : Quantity) вҶ’ Dec (sy ~ q)
sy ~вӮҒ? q
  with рқҹҷ-theQuantity? sy
... | injвӮӮ syвүҒ   = no О» sy~q вҶ’ syвүҒ _ sy~q
... | injвӮҒ (qвҖІ , sy~qвҖІ , unique-qвҖІ)
  with q вүҹ qвҖІ
... | yes refl = yes sy~qвҖІ
... | no  qвүў   = no О» sy~q вҶ’ qвүў (unique-qвҖІ sy~q)

рқҹҷ-theQuantity :
  (sy : Syllable) вҶ’
  вҲғ О» (mq : Flat Quantity) вҶ’
      (sy ~ mq)
    Г— (вҲҖ {mqвҖІ} вҶ’ sy ~ mqвҖІ вҶ’ mqвҖІ вүЎ mq)
рқҹҷ-theQuantity sy
  with рқҹҷ-theQuantity? sy
... | injвӮҒ (q , sy~q , complete-q)
  = single q , byNature sy~q , О» where
    (byNature sy~q) вҶ’ cong single (complete-q sy~q)
    (doubtful syвүҒ) вҶ’ вҠҘ-elim $ syвүҒ q sy~q
... | injвӮӮ syвүҒ
  = none
  , doubtful syвүҒ
  , О» where (byNature sy~q) вҶ’ вҠҘ-elim $ syвүҒ _ sy~q
            (doubtful syвүҒ) вҶ’ refl

рқҹҷ-theQuantities :
  (sys : Syllables n) вҶ’
  вҲғ О» (mqs : Quantities n) вҶ’
      (sys ~ mqs)
    Г— (вҲҖ {mqsвҖІ} вҶ’ sys ~ mqsвҖІ вҶ’ mqsвҖІ вүЎ mqs)
рқҹҷ-theQuantities [] = [] , [] , (О» where [] вҶ’ refl)
рқҹҷ-theQuantities {n = suc n} (sy вҲ· sys) =
  let
    mq , sy~mq , complete-mq = рқҹҷ-theQuantity sy
    mqs , sys~mqs , complete-mqs = рқҹҷ-theQuantities {n = n} sys
  in
    mq вҲ· mqs
  , sy~mq вҲ· sys~mqs
  , О» where (sy~ вҲ· sys~) вҶ’ congвӮӮ _вҲ·_ (complete-mq sy~) (complete-mqs sys~)

